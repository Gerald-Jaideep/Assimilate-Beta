{
  "entities": {
    "User": {
      "title": "User",
      "description": "Healthcare professional profile with learning stats",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string", "enum": ["audience", "speaker", "sponsor", "internal"] } },
        "bio": { "type": "string" },
        "qualifications": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "onboardingCompleted": { "type": "boolean" },
        "stats": {
          "type": "object",
          "properties": {
            "creditPoints": { "type": "number" },
            "sessionsWatched": { "type": "number" },
            "hypePoints": { "type": "number" }
          }
        },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "roles"]
    },
    "UserInteraction": {
      "title": "User Interaction",
      "description": "Represents a user interaction with a case (like, share, bookmark).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "share", "bookmark"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "caseId", "type", "createdAt"]
    },
    "UserCredit": {
      "title": "User Credit",
      "description": "A record of credits earned for a specific activity.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "points": { "type": "number" },
        "specialty": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "caseId", "points", "createdAt"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks the viewing progress of a user for a specific case.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "progress": { "type": "number", "minimum": 0, "maximum": 100 },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "caseId", "progress", "updatedAt"]
    },
    "Hype": {
      "title": "Hype",
      "description": "User backing/hyping a specific clinical case",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System alert or review update for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["review_update", "submission_pending", "overdue", "system"] },
        "caseId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "createdAt"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "Authorization for a speaker/expert to submit a case",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "invitedBy": { "type": "string" },
        "invitedByName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "expired"] },
        "targetRole": { "type": "string", "enum": ["speaker", "expert"] },
        "caseType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "acceptedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "invitedBy", "status", "createdAt"]
    },
    "MedicalCase": {
      "title": "Medical Case",
      "description": "A complex or rare medical case presentation",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "summary": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "duration": { "type": "string" },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "hypes": { "type": "number" },
        "shares": { "type": "number" },
        "bookmarks": { "type": "number" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "specialty": { "type": "string" },
        "transcript": { "type": "string" },
        "presenterId": { "type": "string" },
        "presenterName": { "type": "string" },
        "presenterBio": { "type": "string" },
        "presenterQualifications": { "type": "string" },
        "presenterCountry": { "type": "string" },
        "caseType": { "type": "string", "enum": ["live", "recorded", "structured"] },
        "clinicalData": {
          "type": "object",
          "properties": {
            "presentation": { "type": "string" },
            "history": { "type": "string" },
            "examination": { "type": "string" },
            "investigations": { "type": "array", "items": { "type": "object" } },
            "differentialDiagnosis": { "type": "array", "items": { "type": "string" } },
            "management": { "type": "string" },
            "outcome": { "type": "string" },
            "observations": { "type": "string" },
            "crfData": { "type": "object" }
          }
        },
        "reviewerId": { "type": "string" },
        "reviewerName": { "type": "string" },
        "reviewerPhotoURL": { "type": "string" },
        "reviewerCredentials": { "type": "string" },
        "reviewStatus": { "type": "string", "enum": ["pending", "reviewed", "rejected", "approved"] },
        "reviewNotes": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "reviewQueuePosition": { "type": "number" },
        "reviewDeadline": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "peer_review", "published", "scheduled", "archived"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "googleMeetLink": { "type": "string" },
        "accreditation": {
          "type": "object",
          "properties": {
            "points": { "type": "number" },
            "type": { "type": "string" }
          }
        },
        "isSponsored": { "type": "boolean" },
        "sponsorId": { "type": "string" },
        "sponsorLogo": { "type": "string" },
        "sponsorName": { "type": "string" },
        "sponsorDisclaimer": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "seriesId": { "type": "string" },
        "cmeCredits": { "type": "number" },
        "certificateTemplateId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "presenterId", "status"]
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "Educational grant provider",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "bannerImageUrl": { "type": "string" },
        "profile": { "type": "string" },
        "website": { "type": "string" },
        "disclaimer": { "type": "string" },
        "preRollVideo": { "type": "string" },
        "postRollVideo": { "type": "string" },
        "assets": { "type": "array", "items": { "type": "object" } },
        "assignedUserIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Registration": {
      "title": "Registration",
      "description": "User registration for a scheduled case",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "reminderSet": { "type": "boolean" },
        "registeredAt": { "type": "string", "format": "date-time" }
      }
    },
    "SponsorshipPackage": {
      "title": "Sponsorship Package",
      "description": "Pre-defined sponsorship levels and pricing",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "durationMonths": { "type": "number", "enum": [1, 3, 6, 12] },
        "cost": { "type": "number" },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string", "enum": ["Standard", "Premium", "Elite"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "durationMonths", "cost"]
    },
    "Sponsorship": {
      "title": "Sponsorship",
      "description": "An active sponsorship agreement",
      "type": "object",
      "properties": {
        "sponsorId": { "type": "string" },
        "sponsorName": { "type": "string" },
        "packageId": { "type": "string" },
        "packageName": { "type": "string" },
        "targetType": { "type": "string", "enum": ["single_session", "multiple_sessions", "specialty", "speaker_region"] },
        "targetId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "expired", "pending"] },
        "costPaid": { "type": "number" },
        "metrics": {
          "type": "object",
          "properties": {
            "views": { "type": "number" },
            "brochureDownloads": { "type": "number" },
            "websiteClicks": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sponsorId", "packageId", "targetType", "startDate", "endDate"]
    }
    "Assessment": {
      "title": "Assessment",
      "description": "Assessment for a medical case",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctOptionIndex": { "type": "number" },
              "difficulty": { "type": "string", "enum": ["Simple", "Moderate", "Difficult"] }
            }
          }
        },
        "timeLimitMinutes": { "type": "number" },
        "maxAttempts": { "type": "number" },
        "passPercentage": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "questions", "timeLimitMinutes", "maxAttempts", "passPercentage"]
    },
    "AssessmentAttempt": {
      "title": "Assessment Attempt",
      "description": "User's attempt at an assessment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "assessmentId": { "type": "string" },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "selectedOptionIndex": { "type": "number" },
              "isCorrect": { "type": "boolean" }
            }
          }
        },
        "score": { "type": "number" },
        "passed": { "type": "boolean" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "caseId", "assessmentId", "startedAt"]
    },
    "CertificateTemplate": {
      "title": "Certificate Template",
      "description": "Template for certificates",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["default", "custom", "sponsor"] },
        "sponsorId": { "type": "string" },
        "layoutData": {
          "type": "object",
          "properties": {
            "logoUrl": { "type": "string" },
            "logoPosition": { "type": "object", "properties": { "x": { "type": "number" }, "y": { "type": "number" } } },
            "sponsorLogoUrl": { "type": "string" },
            "sponsorLogoPosition": { "type": "object", "properties": { "x": { "type": "number" }, "y": { "type": "number" } } },
            "textElements": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "text": { "type": "string" },
                  "position": { "type": "object", "properties": { "x": { "type": "number" }, "y": { "type": "number" } } },
                  "fontSize": { "type": "number" },
                  "color": { "type": "string" }
                }
              }
            }
          }
        },
        "backgroundUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "createdAt"]
    },
    "UserCertificate": {
      "title": "User Certificate",
      "description": "Certificate awarded to a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "caseId": { "type": "string" },
        "attemptId": { "type": "string" },
        "certificateTemplateId": { "type": "string" },
        "cmeCreditsEarned": { "type": "number" },
        "issuedAt": { "type": "string", "format": "date-time" },
        "qrCodeData": { "type": "string" },
        "verificationUrl": { "type": "string" },
        "userName": { "type": "string" },
        "caseTitle": { "type": "string" }
      },
      "required": ["userId", "caseId", "attemptId", "issuedAt"]
    }
  },
  "firestore": {
      "schema": "User",
      "description": "User profiles and stats"
    },
    "cases/{caseId}": {
      "schema": "MedicalCase",
      "description": "Expert medical case presentations"
    },
    "sponsors/{sponsorId}": {
      "schema": "Sponsor",
      "description": "Healthcare industry sponsors"
    },
    "sponsorship_packages/{packageId}": {
      "schema": "SponsorshipPackage",
      "description": "Available sponsorship levels"
    },
    "sponsorships/{sponsorshipId}": {
      "schema": "Sponsorship",
      "description": "Active and past sponsorships"
    },
    "cases/{caseId}/registrations/{userId}": {
      "schema": "Registration",
      "description": "Event registrations"
    },
    "user_interactions/{interactionId}": {
      "schema": "UserInteraction",
      "description": "Tracks user likes, shares, and bookmarks for clinical cases."
    },
    "user_credits/{creditId}": {
      "schema": "UserCredit",
      "description": "History of credit points earned by users for continuous learning."
    },
    "user_progress/{progressId}": {
      "schema": "UserProgress",
      "description": "Real-time tracking of case viewing progress for session persistence."
    },
    "invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Access control invitations for speakers and experts"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications and alerts"
    },
    "cases/{caseId}/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Assessment questions for a specific case"
    },
    "users/{userId}/assessment_attempts/{attemptId}": {
      "schema": "AssessmentAttempt",
      "description": "User attempts at assessments"
    },
    "certificate_templates/{templateId}": {
      "schema": "CertificateTemplate",
      "description": "Certificate design templates"
    },
    "users/{userId}/certificates/{certificateId}": {
      "schema": "UserCertificate",
      "description": "Certificates issued to users"
    }
  }
}
