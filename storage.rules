rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Storage rules can now query Firestore for role verification
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      let token = request.auth.token;
      let email = token.get('email', token.get('firebase', {}).get('identities', {}).get('email', [''])[0]);
      let emailLower = email.lower();
      return isSignedIn() && (
        emailLower == 'jaideep@assimilate.one' || 
        emailLower == 'jaideep@medvarsity.com'
      );
    }
    
    function isInternal() {
      return isSignedIn() && (isSuperAdmin() || (exists(/databases/(default)/documents/users/$(request.auth.uid)) && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', '') == 'internal'));
    }

    // Default: Deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Publicly readable assets (Landing page images, generic icons)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isInternal();
    }

    // Event specific assets (CME Hero images, presentation thumbnails)
    match /events/{eventId}/{allPaths=**} {
      allow read: if true; 
      allow write: if isInternal();
    }

    // Case Presentation Thumbnails
    match /cases/{allPaths=**} {
      allow read: if true;
      allow write: if isInternal();
    }

    match /case_thumbs/{allPaths=**} {
      allow read: if true;
      allow write: if isInternal();
    }

    // Expert Presenter Assets
    match /presenters/{allPaths=**} {
      allow read: if true;
      allow write: if isInternal();
    }

    // User Profile Photos & Misc User Assets
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isInternal())
                    && request.resource.size < 5 * 1024 * 1024;
    }

    // Sponsor Assets (Logos, Brochures)
    match /sponsors/{sponsorId}/{allPaths=**} {
      allow read: if true;
      allow write: if isInternal() || (isSignedIn() && getUserData().role == 'sponsor');
    }
  }
}
