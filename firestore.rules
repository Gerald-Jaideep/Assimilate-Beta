rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    
    // DEFINITIVE GOD MODE: Authoritative domain and email matching
    function isAdmin() {
      let email = request.auth.token.get('email', '').lower();
      return isSignedIn() && (
        email == 'jaideep@assimilate.one' || 
        email == 'jaideep@medvarsity.com' ||
        email.endsWith('@medvarsity.com') ||
        email.endsWith('@assimilate.one')
      );
    }

    function isVerified() { return isSignedIn() && (isAdmin() || request.auth.token.email_verified == true); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isMedvarsityTeam() { return isAdmin(); }
    function isManager() { return isAdmin(); }

    function hasValidInvitation() {
      let email = request.auth.token.get('email', '').lower();
      // Using email-based ID for invitations to verify authorization without brute-forcing IDs
      return exists(/databases/$(database)/documents/invitations/$(email)) && 
             get(/databases/$(database)/documents/invitations/$(email)).data.status == 'pending';
    }

    match /system_check/connection {
      allow read: if true;
    }

    // --- 1. USERS ---
    match /users/{userId} {
      function isValidUser(data) {
        return (data.get('email', '') is string) && 
               (data.get('roles', []) is list) &&
               (data.get('role', 'audience') is string);
      }
      
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && 
                       isValidUser(incoming()) && 
                       (isAdmin() || (
                         incoming().get('role', 'audience') == 'audience' && 
                         incoming().get('roles', ['audience']) == ['audience']
                       ));
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == userId && isValidUser(incoming()) && (
          // Action: Profile Self-Update & Role Switching
          (incoming().get('roles', []) == existing().get('roles', []) &&
           (incoming().get('role', 'audience') in existing().get('roles', ['audience'])) &&
           incoming().diff(existing()).affectedKeys().hasOnly([
             'role', 'displayName', 'photoURL', 'specialties', 'bio', 
             'onboardingCompleted', 'careerGoal', 'region'
           ]))
        ))
      );
    }

    // --- 2. MEDICAL CASES ---
    match /cases/{caseId} {
      function isValidMedicalCase(data) {
        return data.get('title', '') is string && data.get('title', '').size() <= 200 &&
               data.get('description', '') is string && data.get('description', '').size() <= 10000 &&
               data.get('status', 'draft') in ['draft', 'pending_review', 'peer_review', 'published', 'review', 'archived', 'scheduled'] &&
               data.get('views', 0) is int && data.get('likes', 0) is int &&
               data.get('shares', 0) is int && data.get('bookmarks', 0) is int &&
               data.get('hypes', 0) is int;
      }

      function isPresenter(caseData) {
        return caseData.presenterId == request.auth.uid || isAdmin();
      }

      allow get: if (resource.data.status in ['published', 'scheduled']) || 
                   (isSignedIn() && (isPresenter(resource.data) || isAdmin()));
      allow list: if (isSignedIn() && (
                       isMedvarsityTeam() ||
                       isAdmin() || 
                       resource.data.presenterId == request.auth.uid
                     )) || (resource.data.status in ['published', 'scheduled']);
      
      allow create: if isSignedIn() && 
                       isValidMedicalCase(incoming()) && 
                       (incoming().presenterId == request.auth.uid) &&
                       (isAdmin() || hasValidInvitation()) &&
                       (incoming().status == 'draft');
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isValidMedicalCase(incoming()) && (
          // Action: Presenter Metadata Update & Workflow Submission
          (isPresenter(existing()) && (
            incoming().diff(existing()).affectedKeys().hasOnly([
              'title', 'subtitle', 'description', 'videoUrl', 'thumbnailUrl', 
              'accreditation', 'presenterName', 'presenterBio', 'presenterQualifications',
              'presenterPublications', 'presenterDisclaimer', 'presenterCountry', 'specialty',
              'scheduledAt', 'googleMeetLink', 'isSponsored', 'sponsorId', 'sponsorLogo', 
              'sponsorName', 'sponsorDisclaimer', 'expiryDate', 'status', 'updatedAt',
              'views', 'likes', 'shares', 'bookmarks', 'hypes'
            ]) &&
            (incoming().get('updatedAt', request.time) == request.time) &&
            (incoming().presenterId == existing().presenterId) &&
            // Presenters can only move status under specific conditions
            (incoming().status == existing().status || (
              // All status transitions must follow a strict state machine
              (existing().status == 'draft' && incoming().status in ['pending_review', 'review', 'scheduled']) ||
              (existing().status == 'scheduled' && incoming().status == 'published' && isAdmin()) ||
              (existing().status == 'review' && incoming().status in ['published', 'draft'] && isAdmin()) ||
              (existing().status == 'published' && incoming().status in ['archived', 'draft'] && isAdmin()) ||
              (existing().status == 'archived' && incoming().status == 'draft' && isAdmin())
            ))
          )) ||
          // Action: Public Interaction Update (Strictly limited to counters)
          (incoming().diff(existing()).affectedKeys().hasOnly(['views', 'likes', 'shares', 'bookmarks', 'hypes']) &&
           incoming().title == existing().title &&
           incoming().status == existing().status &&
           // Counter logic: ensure only increments/decrements of 1 are possible for protected fields
           (!incoming().diff(existing()).affectedKeys().hasAny(['hypes']) || (
             (incoming().hypes == existing().hypes + 1 && exists(/databases/$(database)/documents/hypes/$(request.auth.uid + "_" + caseId))) ||
             (incoming().hypes == existing().hypes - 1 && !exists(/databases/$(database)/documents/hypes/$(request.auth.uid + "_" + caseId)))
           ))
          )
        ))
      );
      
      allow delete: if (isSignedIn() || isAdmin()) && isPresenter(existing());
    }

    // --- 3. WORKFLOW & SYSTEM ---
    match /invitations/{email} {
      allow read: if isSignedIn() && (request.auth.token.email.lower() == email.lower() || isAdmin());
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // --- 3. PROGRESS & INTERACTIONS ---
    match /user_progress/{progressId} {
      function isValidProgress(data) {
        return data.userId is string && data.caseId is string &&
               data.status in ['started', 'completed', 'verified'];
      }
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin()) && isValidProgress(incoming()) &&
                       progressId == incoming().userId + "_" + incoming().caseId;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) &&
                       isValidProgress(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'lastStep', 'quizScore', 'progress', 'hasEarnedCredits']) &&
                       incoming().userId == existing().userId;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /user_interactions/{interactionId} {
      function isValidInteraction(data) {
        return data.userId is string && data.caseId is string &&
               data.type in ['like', 'share', 'bookmark', 'hype', 'view'];
      }
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin()) && isValidInteraction(incoming()) &&
                       interactionId == incoming().userId + "_" + incoming().type + "_" + incoming().caseId;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) &&
                       isValidInteraction(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['value', 'updatedAt']) &&
                       incoming().userId == existing().userId;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /user_credits/{creditId} {
      function isValidCredit(data) {
        return data.userId is string && data.caseId is string &&
               (data.points is int || data.points is float);
      }
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin()) && 
                       isValidCredit(incoming()) &&
                       creditId == incoming().userId + "_" + incoming().caseId &&
                       (isAdmin() || (
                         incoming().points == get(/databases/$(database)/documents/cases/$(incoming().caseId)).data.accreditation.points &&
                         get(/databases/$(database)/documents/user_progress/$(creditId)).data.status == 'completed'
                       ));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- 4. CASE SERIES ---
    match /series/{seriesId} {
      function isValidSeries(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.authorId is string;
      }
      allow read: if true;
      allow create: if isVerified() && (isAdmin() || (incoming().authorId == request.auth.uid && isValidSeries(incoming())));
      allow update: if isVerified() && (isAdmin() || (existing().authorId == request.auth.uid &&
                       isValidSeries(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'caseIds', 'updatedAt']) &&
                       incoming().authorId == existing().authorId));
      allow delete: if isVerified() && (isAdmin() || existing().authorId == request.auth.uid);
    }

    // --- 4. SPONSORS ---
    match /sponsors/{sponsorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- 5. REGISTRATIONS ---
    match /cases/{caseId}/registrations/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 6. HYPES ---
    match /hypes/{hypeId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                      request.auth.uid == incoming().userId && 
                      hypeId == request.auth.uid + "_" + incoming().caseId &&
                      !exists(/databases/$(database)/documents/hypes/$(hypeId));
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- 7. CALENDAR EVENTS ---
    match /calendar_events/{eventId} {
      function isValidEvent(data) {
        return data.name is string && data.name.size() <= 200 &&
               data.date is string && data.date.size() <= 20 &&
               data.country is string && data.country.size() <= 10;
      }
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidEvent(incoming());
      allow update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }
  }
}
